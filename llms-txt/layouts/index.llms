{{- /*
  llms.txt — Hugo Module by GetHugoThemes
  https://github.com/gethugothemes/hugo-modules/llms-txt

  Generates /llms.txt following the llmstxt.org specification.
  Grouped by Hugo sections. Respects params.llms.enable, params.llms.include,
  and params.llms.exclude. Supports glob patterns (*, /**).

  Configuration (params.toml):
    [llms]
      enable  = true
      include = ["/blog/**", "/docs/**"]  # if set, only these pages appear
      exclude = ["/blog/draft/"]          # include always wins over exclude

  Glob patterns:
    /about/       exact match
    /blog/*       direct children of /blog/ only
    /blog/**      /blog/ itself and all pages beneath it
*/ -}}

{{- $llms := site.Params.llms | default dict -}}
{{- if ne ($llms.enable | default true) false -}}
{{- $exc := $llms.exclude | default slice -}}
{{- $inc := $llms.include | default slice -}}

{{- /*
  llmsMatch: sets $matched = true if $p matches any pattern in $list.
    - trailing slashes stripped from both sides before matching
    - "/**"  → recursive: matches the root and all pages beneath it
    - "*"    → single-level glob via path.Match
    - exact  → path.Match with no wildcards
*/ -}}

# {{ site.Title }}

> {{ site.Params.metadata.description | default site.Params.description | default site.Title }}

## Pages

{{- /* ---- Home page ---- */ -}}
{{- $p := strings.TrimSuffix site.Home.RelPermalink "/" -}}
{{- $inInc := false -}}
{{- range $inc -}}
  {{- $pat := strings.TrimSuffix . "/" -}}
  {{- if strings.HasSuffix $pat "/**" -}}
    {{- $pfx := strings.TrimSuffix $pat "/**" -}}
    {{- if or (eq $p $pfx) (strings.HasPrefix $p (printf "%s/" $pfx)) -}}{{- $inInc = true -}}{{- end -}}
  {{- else if path.Match $pat $p -}}{{- $inInc = true -}}
  {{- end -}}
{{- end -}}
{{- $inExc := false -}}
{{- range $exc -}}
  {{- $pat := strings.TrimSuffix . "/" -}}
  {{- if strings.HasSuffix $pat "/**" -}}
    {{- $pfx := strings.TrimSuffix $pat "/**" -}}
    {{- if or (eq $p $pfx) (strings.HasPrefix $p (printf "%s/" $pfx)) -}}{{- $inExc = true -}}{{- end -}}
  {{- else if path.Match $pat $p -}}{{- $inExc = true -}}
  {{- end -}}
{{- end -}}
{{- $show := false -}}
{{- if $inInc -}}{{- $show = true -}}
{{- else if $inExc -}}
{{- else if gt (len $inc) 0 -}}
{{- else -}}{{- $show = true -}}
{{- end -}}
{{- if $show }}
- [{{ site.Home.Title | default "Home" }}]({{ site.Home.Permalink }}){{ with site.Home.Params.description | default site.Params.description }}: {{ . }}{{ end }}
{{- end }}

{{- /* ---- Standalone section pages (About, Contact, Pricing, etc.) ---- */ -}}
{{- range site.Sections }}
{{- if and (not .RegularPages) .Title .Permalink }}
{{- $p := strings.TrimSuffix .RelPermalink "/" -}}
{{- $inInc := false -}}
{{- range $inc -}}
  {{- $pat := strings.TrimSuffix . "/" -}}
  {{- if strings.HasSuffix $pat "/**" -}}
    {{- $pfx := strings.TrimSuffix $pat "/**" -}}
    {{- if or (eq $p $pfx) (strings.HasPrefix $p (printf "%s/" $pfx)) -}}{{- $inInc = true -}}{{- end -}}
  {{- else if path.Match $pat $p -}}{{- $inInc = true -}}
  {{- end -}}
{{- end -}}
{{- $inExc := false -}}
{{- range $exc -}}
  {{- $pat := strings.TrimSuffix . "/" -}}
  {{- if strings.HasSuffix $pat "/**" -}}
    {{- $pfx := strings.TrimSuffix $pat "/**" -}}
    {{- if or (eq $p $pfx) (strings.HasPrefix $p (printf "%s/" $pfx)) -}}{{- $inExc = true -}}{{- end -}}
  {{- else if path.Match $pat $p -}}{{- $inExc = true -}}
  {{- end -}}
{{- end -}}
{{- $show := false -}}
{{- if $inInc -}}{{- $show = true -}}
{{- else if $inExc -}}
{{- else if gt (len $inc) 0 -}}
{{- else -}}{{- $show = true -}}
{{- end -}}
{{- if $show }}
- [{{ .Title }}]({{ .Permalink }}){{ with .Params.description }}: {{ . }}{{ end }}
{{- end }}
{{- end }}
{{- end }}

{{- /* ---- Content sections (Blog, Docs, etc.) ---- */ -}}
{{- range site.Sections }}
{{- if .RegularPages }}
{{- $section := . }}
{{- $filteredPages := slice }}
{{- range where .RegularPages ".Permalink" "ne" "" }}
  {{- $p := strings.TrimSuffix .RelPermalink "/" -}}
  {{- $inInc := false -}}
  {{- range $inc -}}
    {{- $pat := strings.TrimSuffix . "/" -}}
    {{- if strings.HasSuffix $pat "/**" -}}
      {{- $pfx := strings.TrimSuffix $pat "/**" -}}
      {{- if or (eq $p $pfx) (strings.HasPrefix $p (printf "%s/" $pfx)) -}}{{- $inInc = true -}}{{- end -}}
    {{- else if path.Match $pat $p -}}{{- $inInc = true -}}
    {{- end -}}
  {{- end -}}
  {{- $inExc := false -}}
  {{- range $exc -}}
    {{- $pat := strings.TrimSuffix . "/" -}}
    {{- if strings.HasSuffix $pat "/**" -}}
      {{- $pfx := strings.TrimSuffix $pat "/**" -}}
      {{- if or (eq $p $pfx) (strings.HasPrefix $p (printf "%s/" $pfx)) -}}{{- $inExc = true -}}{{- end -}}
    {{- else if path.Match $pat $p -}}{{- $inExc = true -}}
    {{- end -}}
  {{- end -}}
  {{- $show := false -}}
  {{- if $inInc -}}{{- $show = true -}}
  {{- else if $inExc -}}
  {{- else if gt (len $inc) 0 -}}
  {{- else -}}{{- $show = true -}}
  {{- end -}}
  {{- if $show }}{{- $filteredPages = $filteredPages | append . }}{{- end }}
{{- end }}
{{- if $filteredPages }}

## {{ $section.Title }}
{{ range $filteredPages }}
{{- if .Title }}
- [{{ .Title }}]({{ .Permalink }}){{ with .Params.description | default (.Summary | plainify | truncate 120) }}: {{ . }}{{ end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

{{- end -}}
