{{- /*
  llms.txt — Hugo Module by GetHugoThemes
  https://github.com/gethugothemes/hugo-modules/llms-txt

  Generates /llms.txt following the llmstxt.org specification.
  Grouped by Hugo sections. Respects params.llms.enable, include, and exclude.
*/ -}}

{{- define "partials/llms_is_valid_page.html" -}}
{{- $url := .url -}}
{{- $includeList := .includeList -}}
{{- $excludeList := .excludeList -}}
{{- $isIncluded := false -}}
{{- if eq (len $includeList) 0 }}{{ $isIncluded = true }}{{ else -}}
{{- range $includeList -}}
  {{- if strings.HasSuffix . "/**" }}{{ if strings.HasPrefix $url (strings.TrimSuffix "/**" .) }}{{ $isIncluded = true }}{{ end -}}
  {{- else if strings.HasSuffix . "/*" }}{{ $dir := strings.TrimSuffix "*" . }}{{ if and (strings.HasPrefix $url $dir) (ne $url $dir) (not (strings.Contains (strings.TrimSuffix "/" (strings.TrimPrefix $dir $url)) "/")) }}{{ $isIncluded = true }}{{ end -}}
  {{- else }}{{ if eq $url . }}{{ $isIncluded = true }}{{ end -}}
  {{- end -}}
{{- end -}}
{{- end -}}
{{- $isExcluded := false -}}
{{- range $excludeList -}}
  {{- if strings.HasSuffix . "/**" }}{{ if strings.HasPrefix $url (strings.TrimSuffix "/**" .) }}{{ $isExcluded = true }}{{ end -}}
  {{- else if strings.HasSuffix . "/*" }}{{ $dir := strings.TrimSuffix "*" . }}{{ if and (strings.HasPrefix $url $dir) (ne $url $dir) (not (strings.Contains (strings.TrimSuffix "/" (strings.TrimPrefix $dir $url)) "/")) }}{{ $isExcluded = true }}{{ end -}}
  {{- else }}{{ if eq $url . }}{{ $isExcluded = true }}{{ end -}}
  {{- end -}}
{{- end -}}
{{- return (and $isIncluded (not $isExcluded)) -}}
{{- end -}}

{{- $llms := site.Params.llms | default dict -}}
{{- if ne ($llms.enable | default true) false -}}
{{- $rawExcludeList := $llms.exclude | default slice -}}
{{- $includeList := $llms.include | default slice -}}

{{- /* Clean Exclude List (Include takes precedence for exact matches) */ -}}
{{- $excludeList := slice -}}
{{- range $rawExcludeList -}}
  {{- if not (in $includeList .) -}}
    {{- $excludeList = $excludeList | append . -}}
  {{- end -}}
{{- end -}}

# {{ site.Title }}

> {{ site.Params.metadata.description | default site.Params.description | default site.Title }}

## Pages

{{- $home := site.Home }}
{{- $showHome := partial "llms_is_valid_page.html" (dict "url" $home.RelPermalink "includeList" $includeList "excludeList" $excludeList) }}
{{- if $showHome }}
- [{{ $home.Title | default "Home" }}]({{ $home.Permalink }}){{ with $home.Params.description }}: {{ . }}{{ end }}
{{- end }}


{{- range site.Sections }}
{{- if not .RegularPages }}
{{- if and .Title .Permalink }}
{{- $show := partial "llms_is_valid_page.html" (dict "url" .RelPermalink "includeList" $includeList "excludeList" $excludeList) }}
{{- if $show }}
- [{{ .Title }}]({{ .Permalink }}){{ with .Params.description }}: {{ . }}{{ end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

{{- range site.Home.RegularPages }}
{{- $show := partial "llms_is_valid_page.html" (dict "url" .RelPermalink "includeList" $includeList "excludeList" $excludeList) }}
{{- if $show }}
- [{{ .Title }}]({{ .Permalink }}){{ with .Params.description | default (.Summary | plainify | truncate 120) }}: {{ . }}{{ end }}
{{- end }}
{{- end }}

{{- /* Content sections: Blog, Docs etc. */ -}}
{{- range site.Sections }}
{{- if .RegularPages }}
{{- $section := . }}
{{- $validPages := where .RegularPages ".Permalink" "ne" "" }}
{{- $filteredPages := slice }}
{{- range $validPages }}
  {{- $page := . }}
  {{- $show := partial "llms_is_valid_page.html" (dict "url" $page.RelPermalink "includeList" $includeList "excludeList" $excludeList) }}
  {{- if $show }}{{- $filteredPages = $filteredPages | append $page }}{{- end }}
{{- end }}
{{- if $filteredPages }}

## {{ $section.Title }}
{{- $showSection := partial "llms_is_valid_page.html" (dict "url" $section.RelPermalink "includeList" $includeList "excludeList" $excludeList) }}
{{- if $showSection }}
- [{{ $section.Title }}]({{ $section.Permalink }}){{ with $section.Params.description | default ($section.Summary | plainify | truncate 120) }}: {{ . }}{{ end }}
{{- end }}
{{ range $filteredPages }}
{{- if .Title }}
- [{{ .Title }}]({{ .Permalink }}){{ with .Params.description | default (.Summary | plainify | truncate 120) }}: {{ . }}{{ end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

{{- /* Taxonomy list and term pages */ -}}
{{- range $taxonomyName, $taxonomy := site.Taxonomies }}
{{- $taxPage := site.GetPage $taxonomyName }}
{{- if $taxPage }}
{{- $showTax := partial "llms_is_valid_page.html" (dict "url" $taxPage.RelPermalink "includeList" $includeList "excludeList" $excludeList) }}
{{- if $showTax }}

## {{ $taxPage.Title | default ($taxonomyName | humanize) }}
- [{{ $taxPage.Title | default ($taxonomyName | humanize) }}]({{ $taxPage.Permalink }}){{ with $taxPage.Params.description }}: {{ . }}{{ end }}
{{- range $termName, $weightedPages := $taxonomy }}
{{- $termPage := site.GetPage (printf "%s/%s" $taxonomyName $termName) }}
{{- if $termPage }}
{{- $showTerm := partial "llms_is_valid_page.html" (dict "url" $termPage.RelPermalink "includeList" $includeList "excludeList" $excludeList) }}
{{- if $showTerm }}
- [{{ $termPage.Title | default $termName }}]({{ $termPage.Permalink }}){{ with $termPage.Params.description }}: {{ . }}{{ end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

{{- end -}}
