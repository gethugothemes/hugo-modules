{{- /*
  llms.txt — Hugo Module by GetHugoThemes
  https://github.com/gethugothemes/hugo-modules/llms-txt

  Generates /llms.txt following the llmstxt.org specification.
  Grouped by Hugo sections. Respects params.llms.enable, params.llms.include,
  and params.llms.exclude. Supports glob patterns (*, /**).

  Configuration (params.toml):
    [llms]
      enable  = true
      include = ["/blog/**", "/docs/**"]  # if set, only these pages appear
      exclude = ["/blog/draft/"]          # include always wins over exclude
*/ -}}

{{- $llms := site.Params.llms | default dict -}}
{{- if ne ($llms.enable | default true) false -}}
{{- $excludeList := $llms.exclude | default slice -}}
{{- $includeList := $llms.include | default slice -}}

# {{ site.Title }}

> {{ site.Params.metadata.description | default site.Params.description | default site.Title }}

## Pages

{{- $args := dict "include" $includeList "exclude" $excludeList -}}

{{- /* Home page */ -}}
{{- if partial "llms-show.html" (merge $args (dict "path" site.Home.RelPermalink)) }}
- [{{ site.Home.Title | default "Home" }}]({{ site.Home.Permalink }}){{ with site.Home.Params.description | default site.Params.description }}: {{ . }}{{ end }}
{{- end }}

{{- /* Standalone section pages (no child pages — e.g. About, Contact, Pricing) */ -}}
{{- range site.Sections }}
{{- if and (not .RegularPages) .Title .Permalink }}
{{- if partial "llms-show.html" (merge $args (dict "path" .RelPermalink)) }}
- [{{ .Title }}]({{ .Permalink }}){{ with .Params.description }}: {{ . }}{{ end }}
{{- end }}
{{- end }}
{{- end }}

{{- /* Content sections (Blog, Docs, etc.) */ -}}
{{- range site.Sections }}
{{- if .RegularPages }}
{{- $section := . }}
{{- $filteredPages := slice }}
{{- range where .RegularPages ".Permalink" "ne" "" }}
  {{- if partial "llms-show.html" (merge $args (dict "path" .RelPermalink)) }}
    {{- $filteredPages = $filteredPages | append . }}
  {{- end }}
{{- end }}
{{- if $filteredPages }}

## {{ $section.Title }}
{{ range $filteredPages }}
{{- if .Title }}
- [{{ .Title }}]({{ .Permalink }}){{ with .Params.description | default (.Summary | plainify | truncate 120) }}: {{ . }}{{ end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

{{- end -}}
